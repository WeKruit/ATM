# ATM API — Required
ATM_DEPLOY_SECRET=your-deploy-secret-here
GH_DEPLOY_PORT=8080
GH_ENVIRONMENT=staging

# GH Service Ports (default values shown)
GH_API_HOST=localhost
GH_API_PORT=3100
GH_WORKER_HOST=localhost
GH_WORKER_PORT=3101

# ECR Registry
ECR_REGISTRY=168495702277.dkr.ecr.us-east-1.amazonaws.com
ECR_REPOSITORY=ghosthands
AWS_REGION=us-east-1

# AWS CLI (needed for ECR auth in Kamal deploys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Docker
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_CONFIG_PATH=/docker-config/config.json

# Infisical — self-hosted secrets manager (replaces AWS SM)
INFISICAL_SITE_URL=https://infisical-wekruit.fly.dev
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=staging

# AWS Secrets Manager (legacy — will be replaced by Infisical)
# AWS_REGION=us-east-1

# EC2 Idle Monitor — auto-stop ASG-managed GhostHands workers after idle timeout
# AWS_ASG_NAME=ghosthands-worker-asg  # Required: ASG name managed by the idle monitor
# EC2_IDLE_ENABLED=true           # Enable idle auto-stop (default: false)
# EC2_IDLE_TIMEOUT_MS=1800000     # Idle threshold in ms (default: 300000). Staging uses 1800000 (30 min).
# EC2_MIN_RUNNING=0               # Minimum running workers to keep alive (default: 0)
# EC2_POLL_INTERVAL_MS=60000      # Health poll interval in ms (default: 60000 = 1 min)
#
# Note: Waking a fully stopped ASG worker may log a non-fatal
# "exitStandby failed ... not in Standby" warning. This is expected when the
# instance has already transitioned from standby to stopped. ATM proceeds with
# ec2:StartInstances regardless and the wake completes normally.

# GitHub token for canonical secrets fanout (push to GitHub Actions environments)
# Needs repo + environment scope across WeKruit repos
# WORKSPACE_GITHUB_TOKEN=

# Container passthrough env vars (forwarded to GH containers)
# DATABASE_URL=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
